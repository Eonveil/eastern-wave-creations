---
---
<section class="pilots" id="pilots">
  <div class="container">
    <div class="section-header">
      <span class="section-tag">Case Studies</span>
      <h2 class="section-title">Active <span class="text-gradient">Pilots</span> & Work</h2>
      <p class="section-subtitle">
        Explore how we are helping educational institutions and businesses modernize their frontends and automate communications.
      </p>
    </div>
    
    <div class="pilots-list">
      <div class="pilot-card glass-panel">
        <div class="pilot-badge">Launch: 3rd Term 2026</div>
        <div class="pilot-content">
          <h3 class="pilot-title">Durban Academy High School</h3>
          <p class="pilot-desc">
            Deploying a headless School OS portal and an automated WhatsApp Business API pipeline to digitize calendars, sports fixtures, and parent communications.
          </p>
          <div class="pilot-features">
            <span class="feature-tag">Headless Frontends</span>
            <span class="feature-tag">WhatsApp API Bots</span>
            <span class="feature-tag">Automated Workflows</span>
          </div>
          <a href="/case-studies/durban-academy" class="btn-secondary pilot-btn">
            Read Case Study
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .pilots {
    padding: 120px 24px;
    position: relative;
    z-index: 2;
    border-top: 1px solid var(--border-color);
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-header {
    text-align: center;
    max-width: 700px;
    margin: 0 auto 64px auto;
  }

  .section-tag {
    color: var(--accent-cyan);
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    display: inline-block;
    margin-bottom: 12px;
  }

  .section-title {
    font-size: clamp(2rem, 4vw, 3rem);
    margin-bottom: 20px;
  }

  .section-subtitle {
    font-size: 1.1rem;
    color: var(--text-secondary);
  }

  /* Pilot Card */
  .pilot-card {
    display: grid;
    grid-template-columns: 1fr;
    position: relative;
    padding: 48px;
    overflow: hidden;
  }

  .pilot-card::after {
    content: '';
    position: absolute;
    top: -50%;
    right: -20%;
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, rgba(14, 165, 233, 0.06) 0%, rgba(0,0,0,0) 70%);
    filter: blur(30px);
    pointer-events: none;
  }

  .pilot-badge {
    position: absolute;
    top: 24px;
    right: 24px;
    background: rgba(16, 185, 129, 0.08);
    border: 1px solid rgba(16, 185, 129, 0.2);
    color: var(--accent-whatsapp);
    font-size: 0.8rem;
    font-weight: 600;
    padding: 6px 14px;
    border-radius: 20px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .pilot-content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .pilot-title {
    font-size: 1.8rem;
    margin-bottom: 16px;
    font-weight: 700;
  }

  .pilot-desc {
    font-size: 1.1rem;
    color: var(--text-secondary);
    margin-bottom: 24px;
    max-width: 760px;
  }

  .pilot-features {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 32px;
  }

  .feature-tag {
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--text-secondary);
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid var(--border-color);
    padding: 4px 12px;
    border-radius: 12px;
  }

  .pilot-btn {
    padding: 10px 24px;
    font-size: 0.9rem;
  }

  @media (max-width: 768px) {
    .pilot-card {
      padding: 32px 24px;
    }
    
    .pilot-badge {
      position: relative;
      top: 0;
      right: 0;
      align-self: flex-start;
      margin-bottom: 20px;
    }
    
    .pilot-title {
      font-size: 1.5rem;
    }
  }
</style>
