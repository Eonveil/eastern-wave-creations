---
import { createClient } from '@supabase/supabase-js';

const supabaseUrl = process.env.SUPABASE_DATABASE_URL || import.meta.env.SUPABASE_DATABASE_URL || process.env.SUPABASE_URL || import.meta.env.SUPABASE_URL || '';
const supabaseAnonKey = process.env.SUPABASE_ANON_KEY || import.meta.env.SUPABASE_ANON_KEY || '';

let settings = {
  email: "info@easternwavecreations.co.za",
  phone: "Text 'hello' to test our live flow"
};

if (supabaseUrl && supabaseAnonKey) {
  try {
    const supabase = createClient(supabaseUrl, supabaseAnonKey, { db: { schema: 'ewc_secure' } });
    const { data, error } = await supabase
      .from('vault_config')
      .select('email, phone')
      .eq('id', 1)
      .single();
    if (data && !error) {
      settings.email = data.email;
      settings.phone = data.phone;
    }
  } catch (e) {
    console.error("Failed to load settings in Contact.astro:", e);
  }
}
---
<section class="contact" id="contact">
  <div class="container">
    <div class="contact-grid">
      <div class="contact-info">
        <h2 class="contact-title">Let's Create <span class="text-gradient">Something Wavey</span></h2>
        <p class="contact-desc">
          Ready to take your digital experience to the next level? Get in touch to discuss headless frontends, automated WhatsApp integrations, or custom dev solutions.
        </p>
        
        <div class="contact-details">
          <div class="detail-item">
            <span class="detail-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
            </span>
            <div>
              <h4>Email us directly</h4>
              <p id="contact-email-text">{settings.email}</p>
            </div>
          </div>
          
          <div class="detail-item">
            <span class="detail-icon wa-brand-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>
            </span>
            <div>
              <h4>WhatsApp Chatbot Demo</h4>
              <p id="contact-whatsapp-text">{settings.phone}</p>
            </div>
          </div>
        </div>
      </div>
      
      <div class="contact-form-panel glass-panel" id="form-panel">
        <form class="contact-form" id="eastern-contact-form">
          <div class="form-row">
            <div class="form-group">
              <label for="name">Name</label>
              <input type="text" id="name" name="name" required placeholder="John Doe" />
            </div>
            <div class="form-group">
              <label for="email">Email</label>
              <input type="email" id="email" name="email" required placeholder="john@example.com" />
            </div>
          </div>
          
          <div class="form-group">
            <label for="service">Select Service</label>
            <select id="service" name="service" required>
              <option value="" disabled selected>Choose a solution</option>
              <option value="headless-website">Headless Web Development</option>
              <option value="whatsapp-automation">WhatsApp Automation</option>
              <option value="both">Both Solutions Combined</option>
              <option value="other">Other Inquiry</option>
            </select>
          </div>
          
          <div class="form-group">
            <label for="message">Your Project Brief</label>
            <textarea id="message" name="message" rows="5" required placeholder="Tell us briefly about what you want to automate or build..."></textarea>
          </div>
          
          <button type="submit" class="btn-primary form-submit" id="submit-btn">
            Send Brief
            <span class="btn-loader" id="btn-loader" style="display: none;"></span>
          </button>
        </form>
        
        <div class="success-message" id="success-view" style="display: none;">
          <div class="success-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
          </div>
          <h3>Message Received!</h3>
          <p>Thank you for reaching out. We will review your brief and contact you shortly.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<script define:vars={{ supabaseUrl, supabaseAnonKey }}>
  (async () => {
    if (!supabaseUrl || !supabaseAnonKey) return;
    try {
      const res = await fetch(`${supabaseUrl}/rest/v1/vault_config?id=eq.1`, {
        headers: {
          'apikey': supabaseAnonKey,
          'Accept-Profile': 'ewc_secure'
        }
      });
      const data = await res.json();
      if (data && data[0]) {
        const settings = data[0];
        const emailEl = document.getElementById('contact-email-text');
        const waEl = document.getElementById('contact-whatsapp-text');
        if (settings.email && emailEl) emailEl.textContent = settings.email;
        if (settings.phone && waEl) waEl.textContent = settings.phone;
      }
    } catch (e) {
      console.error("Client-side settings fetch failed:", e);
    }
  })();

  const form = document.getElementById('eastern-contact-form') as HTMLFormElement | null;
  const formPanel = document.getElementById('form-panel');
  const successView = document.getElementById('success-view');
  const submitBtn = document.getElementById('submit-btn');
  const btnLoader = document.getElementById('btn-loader');

  if (form && successView && submitBtn && btnLoader) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      // Visual Loading State
      submitBtn.setAttribute('disabled', 'true');
      btnLoader.style.display = 'inline-block';
      
      const formData = new FormData(form);
      const data = Object.fromEntries(formData.entries());
      
      try {
        // Save to localStorage for local reference/backup
        const existingBriefs = JSON.parse(localStorage.getItem('ewc_briefs') || '[]');
        existingBriefs.unshift(data);
        localStorage.setItem('ewc_briefs', JSON.stringify(existingBriefs));

        // Post to Supabase DB in ewc_secure.client_briefs table
        if (supabaseUrl && supabaseAnonKey) {
          const res = await fetch(`${supabaseUrl}/rest/v1/client_briefs`, {
            method: 'POST',
            headers: {
              'apikey': supabaseAnonKey,
              'Authorization': `Bearer ${supabaseAnonKey}`,
              'Content-Type': 'application/json',
              'Content-Profile': 'ewc_secure'
            },
            body: JSON.stringify({
              name: data.name,
              email: data.email,
              service: data.service,
              message: data.message
            })
          });

          if (!res.ok) {
            throw new Error(`Supabase insert failed with status ${res.status}`);
          }

          // Trigger email notification via serverless function (background)
          fetch('/.netlify/functions/send-brief-email', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json'
            },
            body: JSON.stringify({
              name: data.name,
              email: data.email,
              service: data.service,
              message: data.message
            })
          }).catch(mailErr => console.error("Serverless email trigger failed:", mailErr));
        } else {
          // Simulated fallback delay
          await new Promise(resolve => setTimeout(resolve, 1500));
        }
        
        // Hide form & Show success screen with custom animations
        form.style.display = 'none';
        successView.style.display = 'flex';
      } catch (err) {
        console.error('Error submitting brief:', err);
        submitBtn.removeAttribute('disabled');
        btnLoader.style.display = 'none';
      }
    });
  }
</script>

<style>
  .contact {
    padding: 120px 24px;
    position: relative;
    z-index: 2;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    gap: 80px;
    align-items: center;
  }

  .contact-title {
    font-size: clamp(2rem, 4vw, 2.75rem);
    margin-bottom: 24px;
  }

  .contact-desc {
    font-size: 1.05rem;
    color: var(--text-secondary);
    margin-bottom: 40px;
  }

  .contact-details {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .detail-item {
    display: flex;
    gap: 16px;
    align-items: center;
  }

  .detail-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid var(--border-color);
    color: var(--accent-cyan);
  }

  .wa-brand-icon {
    color: var(--accent-whatsapp);
    background: rgba(16, 185, 129, 0.03);
    border-color: rgba(16, 185, 129, 0.1);
  }

  .detail-item h4 {
    font-size: 0.95rem;
    font-weight: 600;
    margin-bottom: 4px;
  }

  .detail-item p {
    font-size: 0.9rem;
    color: var(--text-muted);
  }

  /* Form Styling */
  .contact-form-panel {
    padding: 48px;
    position: relative;
    min-height: 480px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .form-group label {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--text-secondary);
  }

  .form-group input,
  .form-group select,
  .form-group textarea {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    padding: 12px 16px;
    color: var(--text-primary);
    font-family: var(--font-sans);
    font-size: 0.95rem;
    transition: var(--transition-smooth);
    outline: none;
  }

  .form-group select option {
    background: #0c0d14;
    color: #ffffff;
  }

  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    border-color: var(--accent-cyan);
    background: rgba(255, 255, 255, 0.05);
    box-shadow: 0 0 10px rgba(6, 182, 212, 0.1);
  }

  .form-submit {
    align-self: flex-start;
    cursor: pointer;
    border: none;
  }

  .form-submit:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  /* Loader */
  .btn-loader {
    width: 14px;
    height: 14px;
    border: 2px solid rgba(0, 0, 0, 0.2);
    border-top-color: #000;
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }

  /* Success View */
  .success-message {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    animation: fadeIn 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .success-icon {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    background: rgba(16, 185, 129, 0.1);
    border: 1px solid rgba(16, 185, 129, 0.3);
    color: var(--accent-whatsapp);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 24px;
  }

  .success-message h3 {
    font-size: 1.5rem;
    margin-bottom: 12px;
  }

  .success-message p {
    color: var(--text-secondary);
    max-width: 320px;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* Responsive Design */
  @media (max-width: 991px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 50px;
    }
    
    .contact-form-panel {
      padding: 32px;
    }
  }

  @media (max-width: 576px) {
    .form-row {
      grid-template-columns: 1fr;
    }
  }
</style>
