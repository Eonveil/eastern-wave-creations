---
<section class="hero">
  <div class="container">
    <div class="hero-content">
      <div class="badge">
        <span class="badge-dot"></span>
        <span class="badge-text">Next-Gen Web Design & Automation</span>
      </div>
      
      <h1 class="hero-title">
        We build <span class="text-gradient">cinematic</span> websites & <span class="text-gradient">automated</span> flows.
      </h1>
      
      <p class="hero-subtitle">
        Eastern Wave Creations engineers blazing-fast, secure, headless websites and custom WhatsApp automations designed to scale your business and capture customers 24/7.
      </p>
      
      <div class="hero-actions">
        <a href="#contact" class="btn-primary">
          Start Your Project
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
        </a>
        <a href="#services" class="btn-secondary">Explore Services</a>
      </div>
    </div>
    
    <div class="hero-visual">
      <!-- Ambient Visual Element: Glowing Orb + Cyber Grid representing Waves & Code -->
      <div class="wave-container">
        <div class="wave-mesh"></div>
        <div class="glowing-orb"></div>
        <div class="floating-card glass-panel card-1">
          <div class="card-header">
            <span class="card-icon code-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#0ea5e9" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"></polyline><polyline points="8 6 2 12 8 18"></polyline></svg>
            </span>
            <div class="card-title">
              <h4>Headless Frontend</h4>
              <span>astro.config.mjs</span>
            </div>
          </div>
          <div class="card-body">
            <span class="stat">0.4s</span>
            <span class="stat-label">Page Load Speed</span>
          </div>
        </div>
        
        <div class="floating-card glass-panel card-2">
          <div class="card-header">
            <span class="card-icon chat-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
            </span>
            <div class="card-title">
              <h4>WhatsApp Agent</h4>
              <span>active bots</span>
            </div>
          </div>
          <div class="card-body">
            <span class="stat">24/7</span>
            <span class="stat-label">Automation Active</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding-top: 100px;
    position: relative;
    z-index: 2;
    overflow: hidden;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
    padding: 40px 24px;
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 60px;
    align-items: center;
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    padding: 6px 16px;
    border-radius: 100px;
    margin-bottom: 24px;
  }

  .badge-dot {
    width: 6px;
    height: 6px;
    background-color: var(--accent-cyan);
    border-radius: 50%;
    box-shadow: 0 0 12px var(--accent-cyan);
    animation: pulse 2s infinite;
  }

  .badge-text {
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--text-secondary);
  }

  .hero-title {
    font-size: clamp(2.5rem, 5vw, 4rem);
    line-height: 1.1;
    margin-bottom: 24px;
    font-weight: 800;
  }

  .hero-subtitle {
    font-size: 1.15rem;
    color: var(--text-secondary);
    margin-bottom: 40px;
    max-width: 540px;
  }

  .hero-actions {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  /* Visual Element Styling */
  .hero-visual {
    position: relative;
    height: 450px;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .wave-container {
    position: relative;
    width: 100%;
    height: 100%;
    max-width: 400px;
  }

  .glowing-orb {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 250px;
    height: 250px;
    background: radial-gradient(circle, rgba(14, 165, 233, 0.15) 0%, rgba(16, 185, 129, 0.1) 50%, rgba(0, 0, 0, 0) 100%);
    border-radius: 50%;
    filter: blur(40px);
    animation: float 6s ease-in-out infinite alternate;
  }

  .wave-mesh {
    position: absolute;
    inset: 0;
    border: 1px solid rgba(255, 255, 255, 0.03);
    border-radius: 50%;
    background-image: 
      radial-gradient(ellipse at 50% 50%, transparent 40%, rgba(6, 182, 212, 0.05) 100%);
    transform: rotateX(60deg) rotateY(-10deg) rotateZ(20deg);
    animation: rotateMesh 20s linear infinite;
  }

  /* Floating Cards */
  .floating-card {
    position: absolute;
    padding: 16px;
    width: 240px;
    z-index: 10;
  }

  .card-1 {
    top: 20%;
    left: -10%;
    animation: floatCard1 5s ease-in-out infinite alternate;
  }

  .card-2 {
    bottom: 20%;
    right: -10%;
    animation: floatCard2 6s ease-in-out infinite alternate-reverse;
  }

  .card-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 12px;
  }

  .card-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.05);
  }

  .card-title h4 {
    font-size: 0.9rem;
    font-weight: 600;
  }

  .card-title span {
    font-size: 0.75rem;
    color: var(--text-muted);
    font-family: monospace;
  }

  .card-body {
    display: flex;
    align-items: baseline;
    gap: 8px;
  }

  .stat {
    font-size: 1.5rem;
    font-family: var(--font-display);
    font-weight: 800;
    color: var(--text-primary);
  }

  .stat-label {
    font-size: 0.75rem;
    color: var(--text-secondary);
  }

  /* Animations */
  @keyframes pulse {
    0%, 100% { opacity: 0.5; transform: scale(1); }
    50% { opacity: 1; transform: scale(1.3); }
  }

  @keyframes float {
    0% { transform: translate(-50%, -50%) translateY(-10px); }
    100% { transform: translate(-50%, -50%) translateY(10px); }
  }

  @keyframes rotateMesh {
    0% { transform: rotateX(60deg) rotateY(-10deg) rotateZ(0deg); }
    100% { transform: rotateX(60deg) rotateY(-10deg) rotateZ(360deg); }
  }

  @keyframes floatCard1 {
    0% { transform: translateY(0px) rotate(-1deg); }
    100% { transform: translateY(-15px) rotate(1deg); }
  }

  @keyframes floatCard2 {
    0% { transform: translateY(0px) rotate(1deg); }
    100% { transform: translateY(-12px) rotate(-1deg); }
  }

  /* Responsive Design */
  @media (max-width: 991px) {
    .container {
      grid-template-columns: 1fr;
      gap: 40px;
      text-align: center;
      padding-top: 40px;
    }

    .hero-content {
      align-items: center;
    }

    .hero-subtitle {
      margin-left: auto;
      margin-right: auto;
    }

    .hero-visual {
      height: 350px;
    }

    .card-1 {
      left: 5%;
    }

    .card-2 {
      right: 5%;
    }
  }
</style>
