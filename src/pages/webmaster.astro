---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const supabaseUrl = import.meta.env.SUPABASE_DATABASE_URL || import.meta.env.SUPABASE_URL || '';
const supabaseServiceRole = import.meta.env.SUPABASE_SERVICE_ROLE_KEY || '';
---

<Layout title="Webmaster Console | Eastern Wave Creations">
  <Header />
  <main class="admin-container">
    <div id="supabase-config" data-url={supabaseUrl} data-key={supabaseServiceRole} style="display: none;"></div>
    <div class="glass-panel admin-layout">
      <!-- Sidebar Navigation -->
      <aside class="admin-sidebar">
        <div class="admin-brand">
          <svg viewBox="0 0 100 100" class="sidebar-logo">
            <polygon points="50,10 90,30 90,70 50,90 10,70 10,30" fill="none" stroke="currentColor" stroke-width="8"/>
            <path d="M25,40 L50,25 L75,40 L50,80 Z" fill="currentColor"/>
          </svg>
          <div>
            <h3>Webmaster</h3>
            <span>Eastern Wave Console</span>
          </div>
        </div>
        
        <nav class="sidebar-nav">
          <button class="nav-item active" data-tab="dashboard">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="9"></rect><rect x="14" y="3" width="7" height="5"></rect><rect x="14" y="12" width="7" height="9"></rect><rect x="3" y="16" width="7" height="5"></rect></svg>
            Dashboard
          </button>
          <button class="nav-item" data-tab="briefs">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
            Client Briefs
          </button>
          <button class="nav-item" data-tab="system">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="8" rx="2" ry="2"></rect><rect x="2" y="14" width="20" height="8" rx="2" ry="2"></rect><line x1="6" y1="6" x2="6.01" y2="6"></line><line x1="6" y1="18" x2="6.01" y2="18"></line></svg>
            DNS & Systems
          </button>
          <button class="nav-item" data-tab="profile">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
            Business Profile
          </button>
          <button class="nav-item" data-tab="logs">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"></path><path d="M12 6v6l4 2"></path></svg>
            Watchtower Logs
          </button>
          <button class="logout-btn" id="logout-btn">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line></svg>
            Sign Out
          </button>
        </nav>
      </aside>
      
      <!-- Main Dashboard Content -->
      <section class="admin-content">
        <!-- Tab: Dashboard -->
        <div class="tab-pane active" id="tab-dashboard">
          <h2 class="pane-title">Platform Dashboard</h2>
          
          <div class="stats-grid">
            <div class="stat-card glass-panel">
              <span class="stat-num" id="stat-leads-count">0</span>
              <span class="stat-label">Total Lead Inquiries</span>
            </div>
            <div class="stat-card glass-panel">
              <span class="stat-num text-gradient">Live</span>
              <span class="stat-label">Render Deployment</span>
            </div>
            <div class="stat-card glass-panel">
              <span class="stat-num" style="color: var(--accent-whatsapp);">Active</span>
              <span class="stat-label">WhatsApp Bots</span>
            </div>
            <div class="stat-card glass-panel">
              <span class="stat-num">0.4s</span>
              <span class="stat-label">Astro Page Speed</span>
            </div>
          </div>
          
          <div class="dashboard-table-box glass-panel">
            <h3>Recent Submissions</h3>
            <div class="table-container">
              <table class="leads-table">
                <thead>
                  <tr>
                    <th>Client Name</th>
                    <th>Email Address</th>
                    <th>Service Required</th>
                    <th>Brief Message</th>
                  </tr>
                </thead>
                <tbody id="dashboard-leads-list">
                  <!-- Injected via JavaScript -->
                </tbody>
              </table>
            </div>
          </div>
        </div>
        
        <!-- Tab: Briefs -->
        <div class="tab-pane" id="tab-briefs">
          <h2 class="pane-title">Client Brief Inquiries</h2>
          <p class="pane-desc">This data is collected directly from the contact brief forms submitted on the frontend.</p>
          
          <div class="briefs-list" id="briefs-full-list">
            <!-- Injected via JavaScript -->
          </div>
        </div>
        
        <!-- Tab: System -->
        <div class="tab-pane" id="tab-system">
          <h2 class="pane-title">DNS & System Settings</h2>
          
          <div class="system-grid">
            <div class="system-card glass-panel">
              <h3>Custom Domain Configurations</h3>
              <ul class="system-details">
                <li><strong>Apex domain:</strong> <code>easternwavecreations.co.za</code> &bull; <span class="status-badge success">Verified</span></li>
                <li><strong>Subdomain:</strong> <code>www.easternwavecreations.co.za</code> &bull; <span class="status-badge success">Verified</span></li>
                <li><strong>Nameservers:</strong> Pointed to Render IP <code>216.24.57.1</code></li>
                <li><strong>SSL Certificate:</strong> Let's Encrypt Active</li>
              </ul>
            </div>
            
            <div class="system-card glass-panel">
              <h3>Google Webmaster (Search Console)</h3>
              <ul class="system-details">
                <li><strong>Verification File:</strong> <code>/google-site-verification.html</code> &bull; <span class="status-badge success">Active</span></li>
                <li><strong>Sitemap Index:</strong> <code>/sitemap.xml</code> &bull; <span class="status-badge success">Submitted</span></li>
                <li><strong>Google Crawler:</strong> Allowed (via <code>/robots.txt</code>)</li>
              </ul>
            </div>
            
            <!-- Client Status Controls -->
            <div class="system-card glass-panel">
              <h3>Client controls: Serenity Escape</h3>
              <ul class="system-details" style="gap: 12px; list-style: none; padding-left: 0;">
                <li><strong>Supabase Schema:</strong> <code>serenity_escape</code> &bull; <span class="status-badge success">Connected</span></li>
                <li><strong>Current Status:</strong> <span class="status-badge" id="client-site-status" style="background: rgba(197,168,128,0.1); color: var(--accent-cyan); border: 1px solid rgba(197,168,128,0.2); padding: 2px 8px; border-radius: 10px; font-weight: bold;">Fetching...</span></li>
                <li><strong>Database Server:</strong> <code>xcqdbfdgwqfrxeabrtkg.supabase.co</code></li>
              </ul>
              <button class="btn-primary" id="toggle-killswitch-btn" style="margin-top: 20px; border: none; cursor: pointer; background: var(--accent-cyan); color: #000; padding: 10px 16px; border-radius: 8px; font-weight: bold; width: 100%; transition: opacity 0.3s;" onmouseover="this.style.opacity='0.85';" onmouseout="this.style.opacity='1';">Toggle Site Status ⚡</button>
            </div>
          </div>
        </div>
        
        <!-- Tab: Profile -->
        <div class="tab-pane" id="tab-profile">
          <h2 class="pane-title">Business Profile Settings</h2>
          <p class="pane-desc">Edit your company profile settings. Changes will reflect dynamically on the public pages.</p>
          
          <div class="glass-panel profile-card-settings" style="padding: 32px;">
            <form id="profile-settings-form" style="display: flex; flex-direction: column; gap: 20px; text-align: left;">
              <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 8px;">
                <div class="form-group" style="display: flex; flex-direction: column; gap: 8px;">
                  <label style="font-size: 0.85rem; font-weight: 600; color: var(--text-secondary);">Contact Email</label>
                  <input type="email" id="p-email" required style="background: rgba(255, 255, 255, 0.03); border: 1px solid var(--border-color); border-radius: 8px; padding: 12px 16px; color: var(--text-primary); font-size: 0.95rem; outline: none;" />
                </div>
                
                <div class="form-group" style="display: flex; flex-direction: column; gap: 8px;">
                  <label style="font-size: 0.85rem; font-weight: 600; color: var(--text-secondary);">WhatsApp Label / Info Text</label>
                  <input type="text" id="p-phone" required style="background: rgba(255, 255, 255, 0.03); border: 1px solid var(--border-color); border-radius: 8px; padding: 12px 16px; color: var(--text-primary); font-size: 0.95rem; outline: none;" />
                </div>
              </div>

              
              <div class="form-group" style="display: flex; flex-direction: column; gap: 8px;">
                <label style="font-size: 0.85rem; font-weight: 600; color: var(--text-secondary);">Homepage Tagline / Branding Description</label>
                <textarea id="p-tagline" rows="3" required style="background: rgba(255, 255, 255, 0.03); border: 1px solid var(--border-color); border-radius: 8px; padding: 12px 16px; color: var(--text-primary); font-size: 0.95rem; outline: none; resize: vertical; font-family: inherit;"></textarea>
              </div>
              
              <button type="submit" class="btn-primary" style="align-self: flex-start; cursor: pointer; border: none;">Save Profile Changes</button>
            </form>
            <div id="save-success-msg" style="display: none; color: var(--accent-whatsapp); font-size: 0.95rem; font-weight: 600; margin-top: 16px;">Profile details saved successfully! Refresh the public pages to see changes.</div>
          </div>
        </div>
        
        <!-- Tab: Watchtower Logs -->
        <div class="tab-pane" id="tab-logs">
          <h2 class="pane-title">Watchtower Observability Logs</h2>
          <p class="pane-desc">Headless system logs and observability records tracked dynamically from client applications.</p>
          
          <div class="dashboard-table-box glass-panel">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
              <h3>Live Error & Performance Logs</h3>
              <button class="btn-primary" id="clear-logs-btn" style="border: none; cursor: pointer; padding: 8px 16px; border-radius: 6px; font-size: 0.85rem; font-weight: bold; background: #ef4444; color: #fff;">Clear System Logs 🗑️</button>
            </div>
            
            <div class="table-container">
              <table class="leads-table">
                <thead>
                  <tr>
                    <th>Timestamp</th>
                    <th>Severity</th>
                    <th>Source Component</th>
                    <th>Error Details</th>
                  </tr>
                </thead>
                <tbody id="logs-list">
                  <tr><td colspan="4" style="text-align: center; color: var(--text-muted); padding: 20px;">Loading logs...</td></tr>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </section>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  import { createClient } from '@supabase/supabase-js';

  // Authorization Protection
  if (!localStorage.getItem('ewc_webmaster')) {
    window.location.href = '/webmaster-login';
  }

  // Retrieve Supabase credentials passed from Astro server frontmatter
  const configEl = document.getElementById('supabase-config');
  const sbUrl = configEl ? configEl.getAttribute('data-url') : '';
  const sbKey = configEl ? configEl.getAttribute('data-key') : '';

  // Seeding initial leads if empty
  const defaultLeads = [
    {
      name: "Sipho Khumalo",
      email: "sipho@khumalotech.co.za",
      service: "both",
      message: "Looking for a clean, fast website for our tech startup, integrated with a WhatsApp bot to auto-answer customer queries."
    },
    {
      name: "Jane Smith",
      email: "jane@creativeagency.com",
      service: "headless-website",
      message: "We need a headless Astro portfolio site to showcase our design works. Performance and SEO are our main requirements."
    }
  ];

  let briefs = JSON.parse(localStorage.getItem('ewc_briefs') || '[]');
  if (briefs.length === 0) {
    briefs = defaultLeads;
    localStorage.setItem('ewc_briefs', JSON.stringify(briefs));
  }

  // Initialize shared client-side logic
  (async function initSupabase() {
    let realBookings = [];
    let supabase = null;

    if (sbUrl && sbKey) {
      try {
        supabase = createClient(sbUrl, sbKey, { db: { schema: 'serenity_escape' } });

        // 1. Fetch live client bookings
        const { data: dbBookings, error: errBookings } = await supabase
          .from('bookings')
          .select('*')
          .order('created_at', { ascending: false });

        if (dbBookings && !errBookings) {
          realBookings = dbBookings.map(b => ({
            name: b.name,
            email: b.email,
            service: 'serenity-booking',
            message: `${b.message} (Logged: ${new Date(b.created_at).toLocaleDateString()})`
          }));
        }

        // 2. Fetch system logs from Supabase
        const { data: dbLogs, error: errLogs } = await supabase
          .from('system_logs')
          .select('*')
          .order('created_at', { ascending: false });

        const logsList = document.getElementById('logs-list');
        if (logsList) {
          if (dbLogs && dbLogs.length > 0) {
            logsList.innerHTML = dbLogs.map(log => {
              const severityColor = log.severity === 'fatal' ? '#ef4444' : '#eab308';
              const severityBg = log.severity === 'fatal' ? 'rgba(239, 68, 68, 0.1)' : 'rgba(234, 179, 8, 0.1)';
              const severityBorder = log.severity === 'fatal' ? 'rgba(239, 68, 68, 0.2)' : 'rgba(234, 179, 8, 0.2)';
              return `
                <tr>
                  <td><span style="color: var(--text-muted); font-size: 0.8rem;">${new Date(log.created_at).toLocaleString()}</span></td>
                  <td><span class="status-badge" style="background: ${severityBg}; color: ${severityColor}; border: 1px solid ${severityBorder}; padding: 2px 8px; border-radius: 10px; font-weight: bold; font-size: 0.75rem; text-transform: uppercase;">${log.severity}</span></td>
                  <td><code>${log.source}</code></td>
                  <td><strong style="color: #ffffff; display: block; margin-bottom: 4px;">${log.message}</strong>${log.stack_trace ? `<pre style="margin: 8px 0 0 0; padding: 8px; background: rgba(0,0,0,0.3); border-radius: 4px; font-size: 0.75rem; overflow-x: auto; color: #ef4444; border: 1px solid rgba(239,68,68,0.1);">${log.stack_trace}</pre>` : ''}</td>
                </tr>
              `;
            }).join('');
          } else {
            logsList.innerHTML = `<tr><td colspan="4" style="text-align: center; color: var(--text-muted); padding: 20px;">No system logs found.</td></tr>`;
          }
        }

        // 3. Clear System Logs Handler
        const clearBtn = document.getElementById('clear-logs-btn');
        if (clearBtn) {
          clearBtn.addEventListener('click', async () => {
            if (confirm('Are you sure you want to delete all system logs?')) {
              clearBtn.disabled = true;
              clearBtn.textContent = 'Clearing...';
              
              const { error } = await supabase
                .from('system_logs')
                .delete()
                .neq('severity', 'none');
                
              if (!error) {
                if (logsList) {
                  logsList.innerHTML = `<tr><td colspan="4" style="text-align: center; color: var(--text-muted); padding: 20px;">No system logs found.</td></tr>`;
                }
              } else {
                console.error("Failed to delete logs:", error);
              }
              clearBtn.disabled = false;
              clearBtn.textContent = 'Clear System Logs 🗑️';
            }
          });
        }

        // 4. Fetch live site toggle status
        const { data: configData } = await supabase
          .from('system_config')
          .select('value')
          .eq('key', 'site_status');

        if (configData && configData[0]) {
          updateStatusBadge(configData[0].value);
        }

        // 3. Status Toggle Event Handler
        const toggleBtn = document.getElementById('toggle-killswitch-btn');
        if (toggleBtn) {
          toggleBtn.addEventListener('click', async () => {
            const currentBadge = document.getElementById('client-site-status');
            const currentStatus = currentBadge ? currentBadge.textContent : 'active';
            const nextStatus = currentStatus === 'active' ? 'maintenance' : 'active';

            toggleBtn.disabled = true;
            toggleBtn.textContent = 'Updating...';

            const { error } = await supabase
              .from('system_config')
              .update({ value: nextStatus })
              .eq('key', 'site_status');

            if (!error) {
              updateStatusBadge(nextStatus);
            } else {
              console.error("Status toggle error:", error);
            }
            toggleBtn.disabled = false;
            toggleBtn.textContent = 'Toggle Site Status ⚡';
          });
        }

        // 5. Fetch profile settings from Supabase
        const ewcSupabase = createClient(sbUrl, sbKey, { db: { schema: 'ewc_secure' } });
        const { data: dbSettings, error: errSettings } = await ewcSupabase
          .from('vault_config')
          .select('*')
          .eq('id', 1)
          .single();

        if (dbSettings && !errSettings) {
          if (pEmail) pEmail.value = dbSettings.email;
          if (pPhone) pPhone.value = dbSettings.phone;
          if (pTagline) pTagline.value = dbSettings.tagline;
          settingsLoaded = true;
        }

        // Save settings handler for Supabase
        if (settingsForm && saveSuccessMsg && pEmail && pPhone && pTagline) {
          settingsForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            const submitBtn = settingsForm.querySelector('button[type="submit"]') as HTMLButtonElement | null;
            if (submitBtn) {
              submitBtn.disabled = true;
              submitBtn.textContent = 'Saving...';
            }

            const updatedSettings = {
              email: pEmail.value,
              phone: pPhone.value,
              tagline: pTagline.value
            };

            const { error: saveErr } = await ewcSupabase
              .from('vault_config')
              .update(updatedSettings)
              .eq('id', 1);

            if (submitBtn) {
              submitBtn.disabled = false;
              submitBtn.textContent = 'Save Profile Changes';
            }

            if (!saveErr) {
              saveSuccessMsg.style.display = 'block';
              setTimeout(() => {
                if (saveSuccessMsg) saveSuccessMsg.style.display = 'none';
              }, 3000);
            } else {
              console.error("Failed to save settings to Supabase:", saveErr);
            }
          });
        }
        // 6. Fetch live client briefs from ewc_secure.client_briefs
        const { data: dbBriefs, error: errBriefs } = await ewcSupabase
          .from('client_briefs')
          .select('*')
          .order('created_at', { ascending: false });

        if (dbBriefs && !errBriefs) {
          briefs = dbBriefs.map(b => ({
            name: b.name,
            email: b.email,
            service: b.service,
            message: b.message
          }));
        }

      } catch (e) {
        console.error("Supabase initialisation failed:", e);
      }
    }

    // Combine local briefs with live Supabase client bookings
    const allBriefs = [...realBookings, ...briefs];

    // Update lead count stat
    const leadCountEl = document.getElementById('stat-leads-count');
    if (leadCountEl) {
      leadCountEl.textContent = allBriefs.length.toString();
    }

    // Populate Dashboard Table
    const dashboardTable = document.getElementById('dashboard-leads-list');
    if (dashboardTable) {
      dashboardTable.innerHTML = allBriefs.map(lead => `
        <tr>
          <td><strong>${lead.name}</strong></td>
          <td>${lead.email}</td>
          <td><span class="badge-service">${formatService(lead.service)}</span></td>
          <td class="table-msg-cell">${lead.message}</td>
        </tr>
      `).join('');
    }

    // Populate Full Briefs Tab
    const briefsFullList = document.getElementById('briefs-full-list');
    if (briefsFullList) {
      briefsFullList.innerHTML = allBriefs.map((lead, index) => `
        <div class="brief-card glass-panel">
          <div class="brief-header">
            <div>
              <h3>${lead.name}</h3>
              <a href="mailto:${lead.email}">${lead.email}</a>
            </div>
            <span class="badge-service">${formatService(lead.service)}</span>
          </div>
          <div class="brief-body">
            <p>${lead.message}</p>
          </div>
        </div>
      `).join('');
    }
  })();

  function updateStatusBadge(status) {
    const badge = document.getElementById('client-site-status');
    if (badge) {
      badge.textContent = status;
      if (status === 'active') {
        badge.style.background = 'rgba(16, 185, 129, 0.1)';
        badge.style.color = '#10b981';
        badge.style.borderColor = 'rgba(16, 185, 129, 0.2)';
      } else {
        badge.style.background = 'rgba(239, 68, 68, 0.1)';
        badge.style.color = '#ef4444';
        badge.style.borderColor = 'rgba(239, 68, 68, 0.2)';
      }
    }
  }

  function formatService(srv: string) {
    if (srv === 'headless-website') return 'Headless Website';
    if (srv === 'whatsapp-automation') return 'WhatsApp Automation';
    if (srv === 'both') return 'Website & Automation';
    if (srv === 'serenity-booking') return 'Serenity Booking 🏡';
    return 'Other Inquiry';
  }

  // Tab Swapping
  const navItems = document.querySelectorAll('.nav-item');
  const panes = document.querySelectorAll('.tab-pane');

  navItems.forEach(item => {
    item.addEventListener('click', () => {
      navItems.forEach(i => i.classList.remove('active'));
      panes.forEach(p => p.classList.remove('active'));
      
      item.classList.add('active');
      const tabId = item.getAttribute('data-tab');
      document.getElementById(`tab-${tabId}`)?.classList.add('active');
    });
  });

  // Settings Management
  const defaultSettings = {
    email: "info@easternwavecreations.co.za",
    phone: "Text 'hello' to test our live flow",
    tagline: "Engineering modern websites & intelligent WhatsApp communication pipelines."
  };

  const settingsForm = document.getElementById('profile-settings-form') as HTMLFormElement | null;
  const saveSuccessMsg = document.getElementById('save-success-msg');
  const pEmail = document.getElementById('p-email') as HTMLInputElement | null;
  const pPhone = document.getElementById('p-phone') as HTMLInputElement | null;
  const pTagline = document.getElementById('p-tagline') as HTMLTextAreaElement | null;

  let settingsLoaded = false;

  // Fallback to LocalStorage if Supabase settings didn't load (offline/local development)
  setTimeout(() => {
    if (!settingsLoaded) {
      let localSettings = JSON.parse(localStorage.getItem('ewc_settings') || 'null');
      if (!localSettings) {
        localSettings = defaultSettings;
        localStorage.setItem('ewc_settings', JSON.stringify(localSettings));
      }

      if (pEmail && pPhone && pTagline) {
        pEmail.value = localSettings.email;
        pPhone.value = localSettings.phone;
        pTagline.value = localSettings.tagline;
      }

      if (settingsForm && saveSuccessMsg && pEmail && pPhone && pTagline) {
        settingsForm.addEventListener('submit', (e) => {
          e.preventDefault();
          const updatedSettings = {
            email: pEmail.value,
            phone: pPhone.value,
            tagline: pTagline.value
          };
          localStorage.setItem('ewc_settings', JSON.stringify(updatedSettings));
          
          saveSuccessMsg.style.display = 'block';
          setTimeout(() => {
            if (saveSuccessMsg) saveSuccessMsg.style.display = 'none';
          }, 3000);
        });
      }
    }
  }, 1000);

  // Logout
  document.getElementById('logout-btn')?.addEventListener('click', () => {
    localStorage.removeItem('ewc_webmaster');
    window.location.href = '/';
  });
</script>

