---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const supabaseUrl = process.env.SUPABASE_DATABASE_URL || import.meta.env.SUPABASE_DATABASE_URL || process.env.SUPABASE_URL || import.meta.env.SUPABASE_URL || '';
const supabaseAnonKey = process.env.SUPABASE_ANON_KEY || import.meta.env.SUPABASE_ANON_KEY || '';
---

<Layout title="Webmaster Console Login | Eastern Wave Creations">
  <Header />
  <main class="login-container">
    <div id="supabase-config" data-url={supabaseUrl} data-key={supabaseAnonKey} style="display: none;"></div>
    <div class="glass-panel login-card">
      <div class="login-logo">
        <svg viewBox="0 0 100 100" class="logo-icon">
          <polygon points="50,10 90,30 90,70 50,90 10,70 10,30" fill="none" stroke="currentColor" stroke-width="8"/>
          <path d="M25,40 L50,25 L75,40 L50,80 Z" fill="currentColor"/>
        </svg>
        <span class="logo-text">WEBMASTER PANEL</span>
      </div>
      
      <h2 class="login-title">Authorized Sign-in</h2>
      <p class="login-subtitle">Eastern Wave Platform Console</p>
      
      <form id="webmaster-login-form" class="login-form">
        <div class="form-group">
          <label for="w-email">Webmaster Key Email</label>
          <input type="email" id="w-email" required value="webmaster@gmail.com" />
        </div>
        <div class="form-group">
          <label for="w-pass">Master Password</label>
          <input type="password" id="w-pass" required value="webmaster123" />
        </div>
        <button type="submit" class="btn-primary login-submit">Authorize Console</button>
      </form>
      <div id="error-msg" class="error-message" style="display: none;">Authentication failed. Please check your credentials.</div>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  import { createClient } from '@supabase/supabase-js';

  const configEl = document.getElementById('supabase-config');
  const sbUrl = configEl ? configEl.getAttribute('data-url') : '';
  const sbKey = configEl ? configEl.getAttribute('data-key') : '';

  const form = document.getElementById('webmaster-login-form');
  const errorMsg = document.getElementById('error-msg');

  if (form && errorMsg && sbUrl && sbKey) {
    const supabase = createClient(sbUrl, sbKey, { db: { schema: 'ewc_secure' } });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const email = (document.getElementById('w-email') as HTMLInputElement).value;
      const pass = (document.getElementById('w-pass') as HTMLInputElement).value;

      try {
        const { data, error } = await supabase
          .from('console_auth')
          .select('*')
          .eq('email', email)
          .eq('password_hash', pass)
          .single();

        if (data && !error) {
          localStorage.setItem('ewc_webmaster', 'active');
          window.location.href = '/webmaster';
        } else {
          errorMsg.style.display = 'block';
        }
      } catch (err) {
        console.error("Auth query failed:", err);
        errorMsg.style.display = 'block';
      }
    });
  } else {
    // Local / development fallback if Supabase env vars are not set
    if (form && errorMsg) {
      form.addEventListener('submit', (e) => {
        e.preventDefault();
        const email = (document.getElementById('w-email') as HTMLInputElement).value;
        const pass = (document.getElementById('w-pass') as HTMLInputElement).value;

        if (email === 'webmaster@gmail.com' && pass === 'webmaster123') {
          localStorage.setItem('ewc_webmaster', 'active');
          window.location.href = '/webmaster';
        } else {
          errorMsg.style.display = 'block';
        }
      });
    }
  }
</script>

<style>
  .login-container {
    padding: 140px 24px 80px 24px;
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 80vh;
    position: relative;
    z-index: 2;
  }

  .login-card {
    max-width: 440px;
    width: 100%;
    padding: 48px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .login-logo {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    margin-bottom: 24px;
  }

  .logo-icon {
    width: 64px;
    height: 64px;
    color: var(--accent-cyan);
  }

  .logo-text {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.1rem;
    letter-spacing: 0.1em;
    color: var(--text-primary);
  }

  .login-title {
    font-size: 1.75rem;
    margin-bottom: 6px;
    font-weight: 800;
  }

  .login-subtitle {
    font-size: 0.9rem;
    color: var(--text-muted);
    margin-bottom: 32px;
  }

  .login-form {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
    text-align: left;
  }

  .form-group label {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text-secondary);
  }

  .form-group input {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    padding: 12px 16px;
    color: var(--text-primary);
    font-family: var(--font-sans);
    font-size: 0.95rem;
    outline: none;
    transition: var(--transition-smooth);
  }

  .form-group input:focus {
    border-color: var(--accent-cyan);
    background: rgba(255, 255, 255, 0.05);
  }

  .login-submit {
    width: 100%;
    justify-content: center;
    border: none;
    cursor: pointer;
    margin-top: 10px;
  }

  .error-message {
    margin-top: 20px;
    color: #ef4444;
    font-size: 0.9rem;
    font-weight: 500;
  }
</style>
